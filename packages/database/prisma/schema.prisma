generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

enum ProductType {
  CANDLE
  PERFUME
}

model Product {
  id            String      @id @default(uuid())
  name          String      @unique
  description   String
  brand         String
  type          ProductType
  priceAmount   Float
  priceCurrency String      @db.Char(3)
  scentProfile  Json
  createdAt     DateTime    @default(now())
  updatedAt     DateTime    @updatedAt

  @@index([brand])
  @@index([createdAt(sort: Desc)])
}
