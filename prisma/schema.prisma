generator client {
  provider = "prisma-client"
  output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model Product {
  id           String   @id @default(uuid())
  name         String
  brand        String
  type         String
  price        Float
  description  String
  scentProfile Json
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}
